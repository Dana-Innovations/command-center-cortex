# Cortex OAuth (Sign in with Cortex)
NEXT_PUBLIC_CORTEX_URL=https://cortex-bice.vercel.app
NEXT_PUBLIC_CORTEX_CLIENT_ID=your_cortex_client_id
CORTEX_CLIENT_ID=your_cortex_client_id
# Optional for public PKCE-only clients
# CORTEX_CLIENT_SECRET=your_cortex_client_secret
# Optional — override auto-detected redirect URI (usually not needed)
# NEXT_PUBLIC_CORTEX_REDIRECT_URI=http://localhost:3000/auth/cortex/callback

# Supabase (app storage — user profiles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (AI reply drafting + priority scoring)
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
